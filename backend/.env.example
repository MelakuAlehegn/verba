APP_NAME=document-qa-rag-api
APP_VERSION=0.1.0
ENVIRONMENT=local
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:8080
FRONTEND_URL=http://localhost:8080
GOOGLE_AUTH_URL=https://accounts.google.com/o/oauth2/v2/auth
GOOGLE_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/v1/auth/google/callback
GOOGLE_SCOPE=openid email profile
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/document_qa_rag
REDIS_URL=redis://localhost:6379/0
QDRANT_URL=http://localhost:6333
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=documents
S3_REGION=us-east-1
UPLOAD_ALLOWED_EXTENSIONS=.pdf,.txt,.md,.docx
UPLOAD_MAX_BYTES=26214400
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
SESSION_SECRET=change-me
SESSION_TTL_DAYS=30
